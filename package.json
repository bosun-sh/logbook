{
  "name": "@bosun-sh/logbook",
  "version": "2.0.0",
  "description": "File-system kanban board CLI and MCP server for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "logbook": "bin/logbook.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "quickstart.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/copy-hook-templates.mjs",
    "prepack": "bun run build",
    "start": "bun src/workspace/bin-cli.ts mcp",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test tests/unit/",
    "test:e2e": "bun test tests/e2e/",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "prepare": "node -e \"process.exit(0)\"",
    "prepublishOnly": "bun run typecheck && bun run check && bun test && bun run build",
    "release:dry-run": "bun run typecheck && bun run check && bun test && bun run build && node scripts/npm-pack-dry-run.mjs",
    "release": "bun run release:dry-run && node scripts/npm-publish.mjs",
    "publish:dev": "bun link ."
  },
  "dependencies": {
    "@bosun-sh/ohtools": "^0.1.0",
    "@duckdb/node-api": "1.5.2-r.1",
    "effect": "3.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "husky": "^9.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.7.3"
  }
}
